{
  "name": "chapterai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "dev:3000": "next dev -p 3000",
    "dev:3001": "next dev -p 3001",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3010",
    "dev:clean:3000": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3000",
    "dev:clean:3001": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3001",
    "dev:restore": "npx --yes kill-port 3000 3001 3010 && node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3010",
    "dev:restore:3000": "npx --yes kill-port 3000 3001 3010 && node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3000",
    "dev:restore:3001": "npx --yes kill-port 3000 3001 3010 && node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3001",
    "dev:local": "next dev -H 127.0.0.1 -p 3010",
    "dev:turbo": "next dev --turbo -p 3010",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:prompt-drift": "node scripts/lint-prompt-drift.mjs",
    "lint:no-inline-prompts": "node scripts/check-no-inline-prompts.mjs",
    "pretest": "npm run lint:prompt-drift && npm run lint:no-inline-prompts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.43.0",
    "@tiptap/extension-bubble-menu": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/react": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "@tiptap/suggestion": "^2.27.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "~3.4.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "docx": "^8.5.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.400.0",
    "marked": "^18.0.2",
    "next": "14.2.0",
    "openai": "^4.52.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.52.0",
    "recharts": "^2.15.0",
    "sonner": "^1.5.0",
    "stripe": "^16.0.0",
    "tailwind-merge": "^2.4.0",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.4",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
