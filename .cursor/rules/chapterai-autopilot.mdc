## DATABASE SCHEMA

Always create and use exactly this schema. Generate migration files in /supabase/migrations/.

```sql
-- Users are handled by Supabase Auth (auth.users)

-- User profiles (extends auth.users)
CREATE TABLE profiles (
  id UUID REFERENCES auth.users(id) ON DELETE CASCADE PRIMARY KEY,
  email TEXT NOT NULL,
  full_name TEXT,
  avatar_url TEXT,
  stripe_customer_id TEXT,
  subscription_tier TEXT DEFAULT 'free' CHECK (subscription_tier IN ('free', 'pro')),
  books_generated INT DEFAULT 0,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Book projects
CREATE TABLE books (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  user_id UUID REFERENCES profiles(id) ON DELETE CASCADE NOT NULL,
  title TEXT NOT NULL DEFAULT 'Untitled Book',
  genre TEXT,
  target_audience TEXT,
  tone TEXT,
  raw_idea TEXT,                        -- User's original pitch
  refined_idea TEXT,                    -- AI-refined concept
  idea_conversation JSONB DEFAULT '[]', -- Full idea-refinement chat history
  status TEXT DEFAULT 'idea' CHECK (status IN (
    'idea', 'refining', 'outlining', 'writing', 'editing', 'cover', 'complete'
  )),
  cover_prompt TEXT,                    -- Prompt used to generate cover
  cover_url TEXT,                       -- Supabase Storage URL
  kdp_instructions TEXT,                -- Generated KDP publishing guide
  word_count INT DEFAULT 0,
  chapter_count INT DEFAULT 0,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Book outline
CREATE TABLE outlines (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  book_id UUID REFERENCES books(id) ON DELETE CASCADE NOT NULL UNIQUE,
  sections JSONB NOT NULL DEFAULT '[]', -- Array of {title, description, chapter_count}
  approved BOOLEAN DEFAULT FALSE,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Individual chapters
CREATE TABLE chapters (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  book_id UUID REFERENCES books(id) ON DELETE CASCADE NOT NULL,
  chapter_number INT NOT NULL,
  title TEXT NOT NULL,
  outline_summary TEXT,                 -- What this chapter should cover
  content TEXT,                         -- Full generated chapter content (markdown)
  word_count INT DEFAULT 0,
  status TEXT DEFAULT 'pending' CHECK (status IN (
    'pending', 'generating', 'draft', 'edited', 'approved'
  )),
  generation_count INT DEFAULT 0,       -- How many times regenerated
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW(),
  UNIQUE(book_id, chapter_number)
);

-- Storage: covers bucket
-- supabase storage create covers (public bucket)
-- supabase storage create exports (private bucket)

-- Row Level Security
ALTER TABLE profiles ENABLE ROW LEVEL SECURITY;
ALTER TABLE books ENABLE ROW LEVEL SECURITY;
ALTER TABLE outlines ENABLE ROW LEVEL SECURITY;
ALTER TABLE chapters ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Users own their profile" ON profiles FOR ALL USING (auth.uid() = id);
CREATE POLICY "Users own their books" ON books FOR ALL USING (auth.uid() = user_id);
CREATE POLICY "Users own their outlines" ON outlines FOR ALL
  USING (book_id IN (SELECT id FROM books WHERE user_id = auth.uid()));
CREATE POLICY "Users own their chapters" ON chapters FOR ALL
  USING (book_id IN (SELECT id FROM books WHERE user_id = auth.uid()));
```

